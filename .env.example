# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_WEB3FORMS_ACCESS_KEY: Required for submitting the booking form via Web3Forms API.
# Get your access key at https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY="YOUR_ACCESS_KEY_HERE"

# Google Calendar API Setup
# 1. Your Google Calendar ID (usually your primary email address, e.g. you@gmail.com)
GOOGLE_CALENDAR_ID="primary" 

# 2. In Google Calendar Settings -> "Share with specific people or groups"
# Add this exact email address and give it "Make changes to events" permission:
# ais-sandbox@ais-us-west2-8723e0979e1541eda.iam.gserviceaccount.com

# ---------------------------------------------------------
# EXTERNAL DEPLOYMENT ONLY (Vercel, Netlify, custom VPS)
# If you deploy this code outside of AI Studio, you must generate a Service Account key:
# GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
